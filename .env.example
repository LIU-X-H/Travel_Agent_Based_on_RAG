# ============================================================
# 旅游景点 RAG 项目 - 环境变量模板
# ============================================================
# 使用方式：复制为 .env 并修改对应参数
#   cp .env.example .env
# ============================================================

# -------------------- 向量库路径 --------------------
# Chroma 向量数据持久化目录（默认: ./data/vector_db）
VECTOR_DB_PATH=./data/vector_db

# -------------------- Embedding 模型 --------------------
# BGE 中文 Embedding 模型（HuggingFace ID 或本地路径）
# bge-small-zh-v1.5: 轻量版512维 | bge-base-zh-v1.5: 768维 | bge-large-zh-v1.5: 1024维
EMBEDDING_MODEL_NAME=BAAI/bge-small-zh-v1.5

# Embedding 设备：auto（自动选择GPU/CPU）、cuda、cpu
EMBEDDING_DEVICE=auto

# Embedding 向量维度（bge-small-zh-v1.5 为 512）
EMBEDDING_DIM=512

# 是否归一化向量（BGE 推荐 true）
EMBEDDING_NORMALIZE=true

# -------------------- Chroma 向量库 --------------------
# 集合名称
CHROMA_COLLECTION_NAME=travel_scenic_spots

# 距离度量方式: cosine / l2 / ip
CHROMA_DISTANCE_METRIC=cosine

# -------------------- 检索参数 --------------------
# 语义检索候选数
SEMANTIC_TOP_K=10

# BM25 检索候选数
BM25_TOP_K=10

# 混合检索最终返回数
HYBRID_TOP_K=5

# 相似度阈值（0.0 ~ 1.0，低于此分数被过滤）
SIMILARITY_THRESHOLD=0.0

# -------------------- 混合检索权重 --------------------
# 语义检索权重 alpha，BM25 权重 = 1 - alpha（0.0 ~ 1.0）
HYBRID_ALPHA=0.7

# -------------------- 重排序 --------------------
# 是否启用 ReRank 精排
RERANK_ENABLED=false

# ReRank 模型名称
RERANK_MODEL_NAME=BAAI/bge-reranker-large

# ReRank 保留数
RERANK_TOP_K=3

# -------------------- 文本分块 --------------------
# 分块大小（字符数）
CHUNK_SIZE=512

# 分块重叠大小（字符数）
CHUNK_OVERLAP=64

# 数据导入向量库的批次大小
DATA_IMPORT_BATCH_SIZE=32

# -------------------- LLM 大模型 (# 必填 #) --------------------
# 【必填】LLM API Key（OpenAI 或 DeepSeek 或其他兼容 API）
LLM_API_KEY=sk-your-api-key-here

# 【必填】API 基础地址
# OpenAI 默认: 留空或填 https://api.openai.com/v1
# DeepSeek:     https://api.deepseek.com/v1
# 其他兼容 API: 填入对应 base_url
LLM_API_BASE=https://api.deepseek.com/v1

# 模型名称
# OpenAI:  gpt-3.5-turbo / gpt-4o / gpt-4-turbo
# DeepSeek: deepseek-chat / deepseek-reasoner
LLM_MODEL_NAME=deepseek-chat

# 生成温度（0.0~2.0，越低越确定）
LLM_TEMPERATURE=0.1

# 最大生成 Token 数
LLM_MAX_TOKENS=2048

# -------------------- API 服务 --------------------
# 服务监听地址
API_HOST=0.0.0.0

# 服务端口
API_PORT=8000

# 调试模式
API_DEBUG=true

# -------------------- 日志 --------------------
# 日志级别：DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# 日志文件路径（留空则仅控制台输出）
LOG_FILE=
